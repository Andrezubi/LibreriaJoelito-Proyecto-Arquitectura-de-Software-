@page
@model LibreriaJoelito.Pages.Empleados.EmpleadoGetModel
@{
}

<div class="position-relative">
	<h2>Lista Empleados</h2>
	<a class="btn btn-primary position-absolute top-0 end-0 m-3"
	   asp-area="" asp-page="/EmpleadoCreate">+</a>
</div>

<table class="table">
	<thead class="table-dark">
		<tr>
			<th>Nombre</th>
			<th>Apellidos</th>
			<th>CI</th>
			<th>Fecha Nacimiento</th>
			<th>Email</th>
			<th>Fecha Ingreso</th>
			<th>Acciones</th>
		</tr>
	</thead>

	<tbody>
		@foreach (System.Data.DataRow row in Model.EmpleadoDataTable.Rows)
		{
			<tr>
				<td>@row["Nombre"]</td>
				<td>@row["Apellidos"]</td>
				<td>@row["CI"]</td>
				<td>@row["Fecha_Nacimiento"]</td>
				<td>@row["Email"]</td>
				<td>@row["Fecha_Ingreso"]</td>
				<td>
					<a asp-page="/EmpleadoUpdate" asp-route-id="@row["id"]" class="btn btn-warning btn-sm">Editar</a>
					<a asp-page="/EmpleadoDelete" asp-route-id="@row["id"]" class=" btn btn-warning btn-sm">Eliminar</a>
				</td>
			</tr>
		}
	</tbody>
</table>
