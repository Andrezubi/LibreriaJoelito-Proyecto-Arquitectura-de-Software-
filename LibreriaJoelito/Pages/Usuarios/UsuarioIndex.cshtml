<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@* SCRIPT PARA MODAL DE ACTUALIZACION *@
<script>
	function abrirModalUpdate(id, nombre, paterno, materno, ci, email, complemento, direccion, telefono, ingreso, nacimiento) {
		document.getElementById('edit_id').value = id;
		document.getElementById('edit_nombre').value = nombre;
		document.getElementById('edit_paterno').value = paterno;
		document.getElementById('edit_materno').value = materno;
		document.getElementById('edit_ci').value = ci;
		document.getElementById('edit_complemento').value = complemento;
		document.getElementById('edit_email').value = email;
		document.getElementById('edit_direccion').value = direccion;
		document.getElementById('edit_telefono').value = telefono;
		document.getElementById('edit_fechaIngreso').value = ingreso;
		document.getElementById('edit_fechaNacimiento').value = nacimiento;

		var myModal = new bootstrap.Modal(document.getElementById('modalEditarEmpleado'));
		myModal.show();
	}


		// MANEJAR VALIDACIONES DENTRO MODAL

	function enviarUpdate() {
		const formData = new FormData(document.querySelector("#modalEditarEmpleado form"));

		fetch('?handler=Update', {
			method: 'POST',
			body: formData,
			headers: {
				"RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value
			}
		})
		.then(response => response.json())
		.then(data => {
			if (data.success) {
				location.reload();
			} else {
				const alerta = document.getElementById('alertaErrorModal');
				console.log(data);
				alerta.textContent = data.message;
				alerta.style.display = 'block';
			}
		})
		.catch(error => console.error('Error:', error));
	}

	function prepararEliminacion(id) {
		document.getElementById('idParaEliminar').value = id;
		new bootstrap.Modal(document.getElementById('modalDelete')).show();
	}

</script>



