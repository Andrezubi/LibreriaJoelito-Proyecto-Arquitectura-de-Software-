@page "{id:int}"
@model LibreriaJoelito.Pages.Clientes.DeleteModel
@{
    ViewData["Title"] = "Eliminar Cliente";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="card-title text-center mb-4 display-6">Eliminar Cliente</h2>

                    <p class="text-center text-muted mb-4">
                        ¿Estás seguro que deseas eliminar al siguiente cliente?
                    </p>

                    <table class="table table-borderless mb-4">
                        <tr>
                            <th class="text-muted fw-normal" style="width: 40%">Nombre completo</th>
                            <td>@Model._cliente.Nombre @Model._cliente.ApellidoPaterno @Model._cliente.ApellidoMaterno</td>
                        </tr>
                        <tr>
                            <th class="text-muted fw-normal">CI</th>
                            <td>@Model._cliente.CI @(string.IsNullOrEmpty(Model._cliente.Complemento) ? "" : "- " + Model._cliente.Complemento)</td>
                        </tr>
                        <tr>
                            <th class="text-muted fw-normal">Correo Electrónico</th>
                            <td>@(string.IsNullOrEmpty(Model._cliente.Email) ? "—" : Model._cliente.Email)</td>
                        </tr>
                        <tr>
                            <th class="text-muted fw-normal">Cliente Frecuente</th>
                            <td>@(Model._cliente.EsClienteFrecuente ? "Sí" : "No")</td>
                        </tr>
                        <tr>
                            <th class="text-muted fw-normal">Fecha Registro</th>
                            <td class="text-muted" style="font-size: 0.9rem;">
                                @Model._cliente.FechaRegistro.ToString("dd/MM/yyyy HH:mm")
                            </td>
                        </tr>
                    </table>

                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="_cliente.Id" type="hidden" />
                        <input asp-for="_cliente.Nombre" type="hidden" />
                        <input asp-for="_cliente.ApellidoPaterno" type="hidden" />
                        <input asp-for="_cliente.ApellidoMaterno" type="hidden" />

                        <div class="d-grid gap-2 mt-2">
                            <button type="submit" class="btn btn-outline-danger">Confirmar Eliminación</button>
                            <a asp-page="ClientesGet" class="btn btn-link text-muted">Volver al listado</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
