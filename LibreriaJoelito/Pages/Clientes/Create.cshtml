@page
@model LibreriaJoelito.Pages.Clientes.CreateModel
@{
    ViewData["Title"] = "Registrar Cliente";
}

<div class="form-container">
  <div class="form-header">
    Nuevo Cliente
  </div>
<form method="post">
    <div class="mb-3">
        <label asp-for="Nombre" class="form-label">Nombre</label>
        <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan" required />
    </div>
    <div class="mb-3">
        <label asp-for="Apellido" class="form-label">Apellido</label>
        <input asp-for="Apellido" class="form-control" placeholder="Ej: Pérez" required />
    </div>
    <div class="row">
        <div class="col-md-8 mb-3">
            <label asp-for="CI" class="form-label">CI (Cédula de Identidad)</label>
            <input asp-for="CI" class="form-control" placeholder="Ej: 1234567" required />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Complemento" class="form-label">Comp.</label>
            <input asp-for="Complemento" class="form-control" placeholder="Ej: 1A" />
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label">Correo Electrónico</label>
        <input asp-for="Email" type="email" class="form-control" placeholder="juan@ejemplo.com" />
    </div>
    <div class="mb-3">
        <div class="form-check">
            <input asp-for="EsclienteFrecuente" class="form-check-input" type="checkbox" />
            <label asp-for="EsclienteFrecuente" class="form-check-label">
                Cliente Frecuente
            </label>
        </div>
    </div>

    <div class="d-grid gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Guardar Registro</button>
        <a asp-page="ClientesGet" class="btn btn-link text-muted">Volver al listado</a>
    </div>
</form>
</div>
