@page "{id:int}"
@model LibreriaJoelito.Pages.Clientes.EditModel
@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="card-title text-center mb-4 display-6">Editar Cliente</h2>

                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="Cliente.Id" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Cliente.Nombre" class="form-label">Nombre</label>
                            <input asp-for="Cliente.Nombre" class="form-control" placeholder="Ej: Juan" required />
                            <span asp-validation-for="Cliente.Nombre" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Cliente.Apellido" class="form-label">Apellido</label>
                            <input asp-for="Cliente.Apellido" class="form-control" placeholder="Ej: Pérez" required />
                            <span asp-validation-for="Cliente.Apellido" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Cliente.CI" class="form-label">CI (Cédula de Identidad)</label>
                            <input asp-for="Cliente.CI" class="form-control" placeholder="Ej: 1234567" required />
                            <span asp-validation-for="Cliente.CI" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Cliente.Email" class="form-label">Correo Electrónico</label>
                            <input asp-for="Cliente.Email" type="email" class="form-control" placeholder="juan@ejemplo.com" />
                            <span asp-validation-for="Cliente.Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="Cliente.EsClienteFrecuente" class="form-check-input" type="checkbox" />
                                <label asp-for="Cliente.EsClienteFrecuente" class="form-check-label">
                                    Cliente Frecuente
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                            <a asp-page="Index" class="btn btn-link text-muted">Volver al listado</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
