@page
@Html.AntiForgeryToken()
@model LibreriaJoelito.Pages.Productos.ProductoCreateModel
@{
}

<div class="form-container">

    <div class="form-header">
        Nuevo Producto
    </div>

<form method="post">

    <div class="form-group">
        <label>Nombre</label>
        <input asp-for="@Model.producto.Nombre" type="text" required class="form-control" placeholder="Ej: Lapiz"/>
        <span asp-validation-for="producto.Nombre" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Categoria</label>

        <select asp-for="@Model.producto.IdCategoria" class="form-control">
            <option value=0>Elija una categoría</option>

            @foreach (System.Data.DataRow row in Model.CategoriasDataTable.Rows)
            {
                <option value="@row["Id"]">
                    @row["Nombre"]
                </option>
            }
        </select>
        <span asp-validation-for="producto.IdCategoria" class="text-danger d-block"></span>
        <button type="button" class="btn btn-sistema-outline btn-sm mt-2"
                data-bs-toggle="modal" data-bs-target="#modalCategoria">
            + Nueva Categoría
        </button>

    </div>
    <div class="form-group">
        <label>Marca</label>

        <select asp-for="@Model.producto.IdMarca" class="form-control">
            <option value=0>Elija una marca</option>

            @foreach (System.Data.DataRow row in Model.MarcasDataTable.Rows)
            {
                <option value="@row["Id"]">
                    @row["Nombre"]
                </option>
            }
        </select>
        <span asp-validation-for="producto.IdMarca" class="text-danger d-block"></span>
        @* <button type="button" class="btn btn-sistema-outline btn-sm mt-2"
                data-bs-toggle="modal" data-bs-target="#modalMarca">
            + Nueva Marca
        </button> *@

    </div>

    <div class="form-group">
        <label>Stock</label>
        <input asp-for="@Model.producto.Stock" type="number" value="" required class="form-control" placeholder="Ej: 20" />
        <span asp-validation-for="producto.Stock" class="text-danger"></span>
    </div>
    

    <button type="submit" class="btn btn-sistema" style="margin: 10px 0;">Guardar</button>
    <a asp-page="MostrarProductos" class="btn btn-cancelar" style="margin: 10px 0;">Volver</a>
</form>
</div>
<!-- Modal Categoria -->
<div class="modal fade" id="modalCategoria" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header modal-header-morado">
                <h5>Nueva Categoría</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div id="errorCategoria" class="alert alert-danger" style="display:none;"></div>
                <input type="text" id="nombreCategoria" class="form-control" placeholder="Nombre de la categoría" />
            </div>

            <div class="modal-footer">
                <button class="btn btn-sistema" onclick="crear('categoria')">Guardar</button>
            </div>
        </div>
    </div>
</div>
<!-- Modal Marca -->
<div class="modal fade" id="modalMarca" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header modal-header-morado">
                <h5>Nueva Marca</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div id="errorMarca" class="alert alert-danger" style="display:none;"></div>
                <input type="text" id="nombreMarca" class="form-control" placeholder="Nombre de la marca" />
            </div>

            <div class="modal-footer">
                <button class="btn btn-sistema" onclick="crear('marca')">Guardar</button>
            </div>
        </div>
    </div>
</div>
<script>
    async function crear(tipo) {
        let inputId = tipo === "categoria" ? "nombreCategoria" : "nombreMarca";
        let handler = tipo === "categoria" ? "CrearCategoria" : "CrearMarca";
        let modalId = tipo === "categoria" ? "modalCategoria" : "modalMarca";
        let errorId = tipo === "categoria" ? "errorCategoria" : "errorMarca";

        let nombre = document.getElementById(inputId).value;
        let errorDiv = document.getElementById(errorId);

        // limpiar error anterior
        errorDiv.style.display = "none";
        errorDiv.textContent = "";

        if (!nombre.trim()) {
            errorDiv.textContent = "El nombre es obligatorio";
            errorDiv.style.display = "block";
            return;
        }

        let token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        let response = await fetch(`?handler=${handler}`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "RequestVerificationToken": token
            },
            body: JSON.stringify({ Nombre: nombre })
        });

        let data = await response.json();

        if (!data.ok) {
            errorDiv.textContent = data.mensaje || data.message;
            errorDiv.style.display = "block";
            return;
        }

        // éxito
        location.reload(); // simple como tú quieres
    }
</script>