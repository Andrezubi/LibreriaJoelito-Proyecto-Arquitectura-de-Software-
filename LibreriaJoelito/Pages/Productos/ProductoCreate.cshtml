@page
@Html.AntiForgeryToken()
@model LibreriaJoelito.Pages.Productos.ProductoCreateModel
@{
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3">
        <strong>⚠️ Errores:</strong>
        <div asp-validation-summary="All"></div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="form-container">

    <div class="form-header">
        Nuevo Producto
    </div>

<form method="post">

    <div class="form-group">
        <label>Nombre</label>
        <input asp-for="@Model.Nombre" type="text" required class="form-control" />
    </div>
    <div class="form-group">
        <label>Categoria</label>

        <select asp-for="@Model.IdCategoria" class="form-control">
            <option value=0>Elija Una Categoria</option>

            @foreach (System.Data.DataRow row in Model.CategoriasDataTable.Rows)
            {
                <option value="@row["Id"]">
                    @row["Nombre"]
                </option>
            }
        </select>
            <button type="button" class="btn btn-link" data-bs-toggle="modal" data-bs-target="#modalCategoria">
                + Nueva Categoria
            </button>

    </div>
    <div class="form-group">
        <label>Marca</label>

        <select asp-for="@Model.IdMarca" class="form-control">
            <option value=0>Elija Una Marca</option>

            @foreach (System.Data.DataRow row in Model.MarcasDataTable.Rows)
            {
                <option value="@row["Id"]">
                    @row["Nombre"]
                </option>
            }
        </select>
            <button type="button" class="btn btn-link" data-bs-toggle="modal" data-bs-target="#modalMarca">
                + Nueva Marca
            </button>

    </div>

    <div class="form-group">
        <label>Stock</label>
        <input asp-for="@Model.Stock" type="number" required class="form-control" />
    </div>
    

    <button type="submit" class="btn btn-primary" style="margin: 10px 0;">Guardar</button>
    <a asp-page="MostrarProductos" class="btn btn-secondary" style="margin: 10px 0;">Volver</a>
</form>
</div>
<!-- Modal Categoria -->
<div class="modal fade" id="modalCategoria" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5>Nueva Categoria</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div id="errorCategoria" class="alert alert-danger" style="display:none;"></div>
                <input type="text" id="nombreCategoria" class="form-control" placeholder="Nombre de la categoria" />
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" onclick="crear('categoria')">Guardar</button>
            </div>
        </div>
    </div>
</div>
<!-- Modal Marca -->
<div class="modal fade" id="modalMarca" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5>Nueva Marca</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div id="errorMarca" class="alert alert-danger" style="display:none;"></div>
                <input type="text" id="nombreMarca" class="form-control" placeholder="Nombre de la marca" />
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" onclick="crear('marca')">Guardar</button>
            </div>
        </div>
    </div>
</div>
<script>
    async function crear(tipo) {
        let inputId = tipo === "categoria" ? "nombreCategoria" : "nombreMarca";
        let handler = tipo === "categoria" ? "CrearCategoria" : "CrearMarca";
        let modalId = tipo === "categoria" ? "modalCategoria" : "modalMarca";
        let errorId = tipo === "categoria" ? "errorCategoria" : "errorMarca";

        let nombre = document.getElementById(inputId).value;
        let errorDiv = document.getElementById(errorId);

        // limpiar error anterior
        errorDiv.style.display = "none";
        errorDiv.textContent = "";

        if (!nombre.trim()) {
            errorDiv.textContent = "El nombre es obligatorio";
            errorDiv.style.display = "block";
            return;
        }

        let token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        let response = await fetch(`?handler=${handler}`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "RequestVerificationToken": token
            },
            body: JSON.stringify({ Nombre: nombre })
        });

        let data = await response.json();

        if (!data.ok) {
            errorDiv.textContent = data.mensaje || data.message;
            errorDiv.style.display = "block";
            return;
        }

        // éxito
        location.reload(); // simple como tú quieres
    }
</script>