<!DOCTYPE html>
<html>
<head>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="utf-8" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- GOOGLE FONTS -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/globals.css" />
    <link rel="stylesheet" href="~/css/style.css" />

    <title>@ViewData["Title"]</title>

</head>

<body class="@(ViewData["Title"]?.ToString() == "Index" ? "" : "bg-sistema")">

    <div class="sistema-de-gestion">

        <!-- HEADER -->
        <header class="main-header">

            <div class="header-left">
                <div class="logo"></div>

                <div class="header-text">
                    <div class="titulo-sistema">
                        LIBRERÍA JOELITO
                    </div>
                    <div class="subtitulo-sistema">
                        Sistema de Gestión de Librería
                    </div>
                </div>
            </div>

            <div class="header-right">
                @RenderSection("HeaderButtons", required: false)
            </div>

        </header>

        <!-- CONTENEDOR PRINCIPAL -->
        <div class="main-container">

            @{
                var ocultarSidebar = ViewData["OcultarSidebar"] != null && (bool)ViewData["OcultarSidebar"];
            }

            <!-- SIDEBAR -->
            @if (!ocultarSidebar)
            {
                <aside class="sidebar">

                    <a href="/Index" class="menu-item active">
                        <img class="menu-icon" src="~/img/home-lib.svg">
                        <span>Inicio</span>
                    </a>

                    <!-- PRODUCTOS -->
                    <div class="menu-item d-flex justify-content-between align-items-center">

                        <a href="/Productos/MostrarProductos" class="menu-link d-flex align-items-center">
                            <img class="menu-icon" src="~/img/prod-lib.svg">
                            <span>Productos</span>
                        </a>

                        <span class="flecha-toggle" data-bs-toggle="collapse" data-bs-target="#menuProductos">
                            ▾
                        </span>
                    </div>

                    <!-- SUBMENÚ -->
                    <div class="collapse submenu" id="menuProductos">

                        <a href="/Index" class="submenu-item">
                            <img class="menu-icon" src="~/img/categoria-lib.svg">
                            <span>Categoría</span>
                        </a>

                        <a href="/Marcas/VerMarcas" class="submenu-item">
                            <img class="menu-icon" src="~/img/marca-lib.svg">
                            <span>Marcas Disponibles</span>
                        </a>

                    </div>

                    <a href="/Clientes/ClientesGet" class="menu-item">
                        <img class="menu-icon" src="~/img/cli-lib.svg">
                        <span>Clientes</span>
                    </a>

                    <a href="/Usuarios/UsuarioIndex" class="menu-item">
                        <img class="menu-icon" src="~/img/emp-lib.svg">
                        <span>Usuarios</span>
                    </a>

                    <a href="/Index" class="menu-item">
                        <img class="menu-icon" src="~/img/ventas-lib.svg">
                        <span>Ventas</span>
                    </a>

                    <a href="/Index" class="menu-item">
                        <img class="menu-icon" src="~/img/config-lib.svg">
                        <span>Configuración</span>
                    </a>

                </aside>
            }

            <!-- CONTENIDO -->
            <main class="content-area @(ocultarSidebar ? "full-width" : "")">
                @RenderBody()
            </main>

        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>