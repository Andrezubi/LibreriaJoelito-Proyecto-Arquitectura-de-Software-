@page
@model LibreriaJoelito.Pages.Ventas.RegistrarModel
@{
    ViewData["Title"] = "Registrar Venta";
}

<div class="container mt-4">
    <h2 class="mb-4">REGISTRO DE VENTA</h2>
    
    <div class="card p-4 shadow-sm mb-4">
        <form method="post" id="ventaForm">
            @Html.AntiForgeryToken()
            
            <div class="row g-3 align-items-center bg-light p-3 rounded border">
                <!-- Fecha (Autogenerada) -->
                <div class="col-md-3">
                    <label class="form-label fw-bold">Fecha:</label>
                    <input type="text" class="form-control" value="@DateTime.Now.ToString("dd/MM/yyyy")" disabled>
                </div>

                <!-- Buscador CI/NIT Cliente -->
                <div class="col-md-3">
                    <label for="ciCliente" class="form-label fw-bold">CI/NIT Cliente: <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input type="text" id="ciCliente" class="form-control" placeholder="Buscar CI/NIT..." required autocomplete="off">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    </div>
                    <small id="clienteFeedback" class="form-text text-muted"></small>
                </div>

                <!-- Nombre del Cliente y Botón "+" -->
                <div class="col-md-6">
                    <label for="nombreCliente" class="form-label fw-bold">Cliente/Razón Social:</label>
                    <div class="input-group">
                        <input type="hidden" id="idCliente" name="IdCliente" required>
                        <input type="text" id="nombreCliente" class="form-control bg-white" readonly placeholder="El nombre aparecerá automáticamente">
                        
                        <!-- Botón "+" para abrir Modal (HU-03 Rol B) -->
                        <button type="button" class="btn btn-primary fw-bold" id="btnAbrirModalCliente" data-bs-toggle="modal" data-bs-target="#modalCrearCliente">
                            +
                        </button>
                    </div>
                </div>
            </div>

            <!-- Footer con botón Guardar (Simulacro para HU-02) -->
            <div class="mt-4 text-center">
                <button type="submit" class="btn btn-success px-5 py-2 fw-bold" id="btnGuardarVenta">Guardar Venta</button>
            </div>
        </form>
    </div>
</div>

<!-- ============================================== -->
<!-- MODAL DE CREACIÓN RÁPIDA (HU-03 ROL B)        -->
<!-- ============================================== -->
<div class="modal fade" id="modalCrearCliente" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalLabel">Creación Rápida de Cliente</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formCrearClienteRapido">
                    <div class="mb-3">
                        <label class="form-label fw-bold">CI/NIT:</label>
                        <input type="text" id="modalCi" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre:</label>
                        <input type="text" id="modalNombre" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Apellido Paterno:</label>
                        <input type="text" id="modalApellido" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email (Opcional):</label>
                        <input type="email" id="modalEmail" class="form-control">
                    </div>
                    <div id="modalAlert" class="alert alert-danger d-none" role="alert"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnGuardarClienteModal">Guardar Cliente</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Referencias UI principal
            const ciInput = document.getElementById('ciCliente');
            const nombreInput = document.getElementById('nombreCliente');
            const idClienteInput = document.getElementById('idCliente');
            const feedback = document.getElementById('clienteFeedback');
            const modalEl = new bootstrap.Modal(document.getElementById('modalCrearCliente'));
            
            // Referencias Modal
            const btnAbrirModal = document.getElementById('btnAbrirModalCliente');
            const btnGuardarModal = document.getElementById('btnGuardarClienteModal');
            const modalCi = document.getElementById('modalCi');
            const modalNombre = document.getElementById('modalNombre');
            const modalApellido = document.getElementById('modalApellido');
            const modalEmail = document.getElementById('modalEmail');
            const modalAlert = document.getElementById('modalAlert');

            let timeoutId;

            // --- Lógica de Búsqueda (HU-03 Rol A) ---
            ciInput.addEventListener('input', function () {
                const ciValue = this.value.trim();
                nombreInput.value = '';
                idClienteInput.value = '';
                feedback.textContent = '';
                this.classList.remove('is-invalid', 'is-valid');

                if (ciValue.length >= 4) {
                    clearTimeout(timeoutId);
                    timeoutId = setTimeout(() => {
                        feedback.textContent = "Buscando...";
                        fetch(`?handler=BuscarCliente&ci=${encodeURIComponent(ciValue)}`)
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    const c = data.cliente;
                                    nombreInput.value = `${c.nombre} ${c.apellidoPaterno}${c.apellidoMaterno ? ' ' + c.apellidoMaterno : ''}`;
                                    idClienteInput.value = c.id;
                                    feedback.textContent = "✓ Cliente encontrado";
                                    feedback.className = "form-text text-success";
                                    ciInput.classList.add('is-valid');
                                } else {
                                    feedback.textContent = "✗ No existe. Use el botón '+'";
                                    feedback.className = "form-text text-danger";
                                    ciInput.classList.add('is-invalid');
                                }
                            });
                    }, 400);
                }
            });

            // --- Lógica del Modal (HU-03 Rol B) ---
            
            // Al abrir el modal, heredar el CI si el usuario escribió algo
            btnAbrirModal.addEventListener('click', () => {
                modalCi.value = ciInput.value;
                modalAlert.classList.add('d-none');
            });

            btnGuardarModal.addEventListener('click', function () {
                const clienteData = {
                    Ci: modalCi.value,
                    Nombre: modalNombre.value,
                    ApellidoPaterno: modalApellido.value,
                    Email: modalEmail.value
                };

                // Validacion rápida en cliente
                if (!clienteData.Ci || !clienteData.Nombre || !clienteData.ApellidoPaterno) {
                    modalAlert.textContent = "Por favor, complete los campos obligatorios.";
                    modalAlert.classList.remove('d-none');
                    return;
                }

                // AJAX POST para creación rápida
                fetch('?handler=CrearClienteRapido', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify(clienteData)
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        // 1. Cerrar Modal
                        modalEl.hide();
                        
                        // 2. Auto-seleccionar en la UI principal
                        ciInput.value = clienteData.Ci;
                        nombreInput.value = data.nombre;
                        idClienteInput.value = data.id;
                        
                        // 3. Limpiar feedback
                        feedback.textContent = "✓ Cliente recién creado y seleccionado";
                        feedback.className = "form-text text-success";
                        ciInput.classList.remove('is-invalid');
                        ciInput.classList.add('is-valid');
                    } else {
                        modalAlert.textContent = "Error: " + (data.errors ? data.errors.join(", ") : "Ocurrió un problema.");
                        modalAlert.classList.remove('d-none');
                    }
                })
                .catch(err => {
                    modalAlert.textContent = "Error de conexión al servidor.";
                    modalAlert.classList.remove('d-none');
                });
            });
        });
    </script>
}
