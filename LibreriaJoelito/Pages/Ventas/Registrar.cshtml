@page
@model LibreriaJoelito.Pages.Ventas.RegistrarModel
@{
    ViewData["Title"] = "Registrar Venta";
}

<div class="ventas-page">
    <div class="content-area">
        <div class="ventas-card">
            <h2 class="ventas-titulo">REGISTRO DE VENTA</h2>

            <div class="card p-4 shadow-sm mb-4">
                <form method="post" id="ventaForm">
                    @Html.AntiForgeryToken()

                    <div class="row g-3 align-items-center bg-light p-3 rounded border">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Fecha:</label>
                            <input type="text" class="form-control" value="@DateTime.Now.ToString("dd/MM/yyyy")" disabled>
                        </div>

                        <div class="col-md-3">
                            <label for="ciCliente" class="form-label fw-bold">
                                CI/NIT Cliente: <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input type="text" id="ciCliente" class="form-control" placeholder="Buscar CI/NIT..." required autocomplete="off">
                                <span class="input-group-text bg-white">🔍</span>
                            </div>
                            <small id="clienteFeedback" class="form-text text-muted"></small>
                        </div>

                        <div class="col-md-6">
                            <label for="nombreCliente" class="form-label fw-bold">Cliente/Razón Social:</label>
                            <div class="input-group">
                                <input type="hidden" id="idCliente" name="IdCliente" required>
                                <input type="text" id="nombreCliente" class="form-control bg-white" readonly placeholder="El nombre aparecerá automáticamente">
                                <button type="button" class="btn btn-crear" id="btnCrearClienteRapido">+</button>
                            </div>
                        </div>
                    </div>

                    <br />

                    <div class="row mb-4 justify-content-center">
                        <div class="col-md-8">
                            <div class="input-group">
                                <input type="text" id="productoBusqueda" class="form-control"
                                       placeholder="Buscar producto para vender..." autocomplete="off">
            
                                <button type="button" class="btn btn-primary" onclick="prepararProducto()">
                                    🔍
                                </button>
            
                                <button type="button" class="btn btn-success" id="btnAñadirLista" disabled onclick="confirmarAñadir()">
                                    + Añadir a la venta
                                </button>
                            </div>
                            <ul id="listaProductos" class="list-group position-absolute w-50 shadow"
                                style="z-index: 1050; display: none; max-height: 200px; overflow-y: auto;">
                            </ul>
                            <small id="productoFeedback" class="form-text d-block mt-1"></small>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered" id="tablaProductos">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width: 80px;">Cant.</th>
                                    <th>Descripción</th>
                                    <th>P. Unit (Bs)</th>
                                    <th>Importe (Bs)</th>
                                    <th style="width: 40px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                            <tfoot>
                                <tr class="table-secondary">
                                    <th colspan="3" class="text-end">TOTAL Bs:</th>
                                    <th id="totalVenta" class="fw-bold">0.00</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="ventas-footer mt-4">
                        <button type="submit" class="btn btn-guardar" id="btnGuardarVenta">
                            Registrar Venta
                        </button>
                    </div>
                </form>

                <div class="modal fade" id="modalCliente" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <!-- HEADER -->
                <div class="modal-header modal-header-morado">
                    <h5 class="modal-title">Nuevo Cliente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <div class="form-container" style="box-shadow:none; border:none; padding:0;">

                        <form id="formClienteModal">
                            @Html.AntiForgeryToken()

                            <!-- NOMBRE -->
                            <div class="form-group mb-3">
                                <label class="form-label fw-bold">Nombre</label>
                                <input type="text" id="modalNombre" class="form-control" placeholder="Ej: Juan" required>
                            </div>

                            <!-- APELLIDOS -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Apellido Paterno</label>
                                    <input type="text" id="modalApellidoP" class="form-control" placeholder="Ej: Pérez" required>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Apellido Materno (Opcional)</label>
                                    <input type="text" id="modalApellidoM" class="form-control" placeholder="Ej: López">
                                </div>
                            </div>

                            <!-- CI + COMPLEMENTO -->
                            <div class="row">
                                <div class="col-md-8 mb-3">
                                    <label class="form-label fw-bold">Carnet de Identidad</label>
                                    <input type="text" id="modalCi" class="form-control" placeholder="Ej: 1234567" required>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Complemento</label>
                                    <input type="text" id="modalComplemento" class="form-control" placeholder="Ej: 1A">
                                </div>
                            </div>

                            <!-- EMAIL -->
                            <div class="form-group mb-3">
                                <label class="form-label">Correo Electrónico</label>
                                <input type="email" id="modalEmail" class="form-control" placeholder="juan@ejemplo.com">
                            </div>

                            <!-- CHECK -->
                            <div class="form-group mb-3">
                                <div class="form-check">
                                    <input type="checkbox" id="modalFrecuente" class="form-check-input">
                                    <label class="form-check-label">Es Cliente Frecuente</label>
                                </div>
                            </div>

                            <small id="modalFeedback" class="text-danger"></small>

                        </form>
                    </div>
                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-cancelar" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-sistema" id="btnGuardarClienteModal">
                        Registrar Cliente
                    </button>
                </div>

            </div>
        </div>
    </div>
</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // --- VARIABLES CLIENTE ---
            const ciInput = document.getElementById('ciCliente');
            const nombreInput = document.getElementById('nombreCliente');
            const idClienteInput = document.getElementById('idCliente');
            const feedback = document.getElementById('clienteFeedback');
            const btnGuardarVenta = document.getElementById('btnGuardarVenta');

            // --- VARIABLES MODAL ---
            const modalElement = document.getElementById('modalCliente');
            const modal = new bootstrap.Modal(modalElement);
            const btnCrearCliente = document.getElementById('btnCrearClienteRapido');
            const btnGuardarClienteModal = document.getElementById('btnGuardarClienteModal');
            
            const modalCi = document.getElementById('modalCi');
            const modalNombre = document.getElementById('modalNombre');
            const modalApellidoP = document.getElementById('modalApellidoP');
            const modalApellidoM = document.getElementById('modalApellidoM');
            const modalComplemento = document.getElementById('modalComplemento');
            const modalEmail = document.getElementById('modalEmail');
            const modalFrecuente = document.getElementById('modalFrecuente');
            const modalFeedback = document.getElementById('modalFeedback');
            
            // --- LÓGICA BUSCAR CLIENTE ---
            let timeoutId;
            ciInput.addEventListener('input', function () {
                const ciValue = this.value.trim();
                nombreInput.value = '';
                idClienteInput.value = '';
                if (ciValue.length >= 4) {
                    clearTimeout(timeoutId);
                    timeoutId = setTimeout(() => {
                        fetch(`?handler=BuscarCliente&ci=${encodeURIComponent(ciValue)}`)
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    nombreInput.value = `${data.cliente.nombre} ${data.cliente.apellidoPaterno}`;
                                    idClienteInput.value = data.cliente.id;
                                    feedback.textContent = "Cliente encontrado.";
                                    feedback.className = "form-text text-success";
                                } else {
                                    feedback.textContent = "No existe. Use '+'";
                                    feedback.className = "form-text text-danger";
                                }
                            });
                    }, 400);
                }
            });

        // --- LÓGICA MODAL CLIENTE ---
        btnCrearCliente.addEventListener('click', () => {
            modalCi.value = ciInput.value;
            modal.show();
        });

        btnGuardarClienteModal.addEventListener('click', () => {
            const data = {
                Ci: modalCi.value,
                Nombre: modalNombre.value,
                ApellidoPaterno: modalApellidoP.value,
                ApellidoMaterno: modalApellidoM.value,
                Complemento: modalComplemento.value,
                Email: modalEmail.value,
                ClienteFrecuente: modalFrecuente.checked
            };

            fetch('?handler=CrearCliente', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const c = data.cliente;
                    nombreInput.value = `${c.nombre} ${c.apellidoPaterno} ${c.apellidoMaterno || ''}`.trim();
                    idClienteInput.value = c.id;
                    ciInput.value = c.ci;
                    ciInput.classList.add('is-valid');
                    modal.hide();
                } else {
                    modalFeedback.textContent = data.message;
                }
            });
        });


            // --- LÓGICA BUSCAR PRODUCTO (Sugerencias) ---
            const inputProducto = document.getElementById('productoBusqueda');
            const listaSugerencias = document.getElementById('listaProductos');

            inputProducto.addEventListener('input', function () {
                const term = this.value.trim();
                if (term.length < 2) {
                    listaSugerencias.style.display = 'none';
                    return;
                }
                fetch(`?handler=BuscarNombre&termino=${encodeURIComponent(term)}`)
                    .then(res => res.json())
                    .then(data => {
                        listaSugerencias.innerHTML = '';
                        if (data && data.length > 0) {
                            data.forEach(nombre => {
                                const li = document.createElement('li');
                                li.className = 'list-group-item list-group-item-action';
                                li.textContent = nombre;
                                li.onclick = function() {
                                    inputProducto.value = nombre;
                                    listaSugerencias.style.display = 'none';
                                    // CORRECCIÓN: Llamamos a prepararProducto en lugar de agregarProducto
                                    prepararProducto();
                                };
                                listaSugerencias.appendChild(li);
                            });
                            listaSugerencias.style.display = 'block';
                        }
                    });
            });
        });

        // --- LÓGICA PARA AGREGAR PRODUCTOS A LA TABLA ---
        let productoTemporal = null;

        window.prepararProducto = function() {
            const nombreBusqueda = document.getElementById('productoBusqueda').value.trim();
            const feedback = document.getElementById('productoFeedback');
            const btnAñadir = document.getElementById('btnAñadirLista');

            if (!nombreBusqueda) return;

            fetch(`?handler=ObtenerDetalleProducto&nombre=${encodeURIComponent(nombreBusqueda)}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        productoTemporal = data.producto;
                        feedback.textContent = `Seleccionado: ${data.producto.nombre} - Bs. ${data.producto.precioUnitario.toFixed(2)}`;
                        feedback.className = "form-text text-success fw-bold";
                        btnAñadir.disabled = false;
                    } else {
                        productoTemporal = null;
                        feedback.textContent = "Producto no encontrado.";
                        feedback.className = "form-text text-danger";
                        btnAñadir.disabled = true;
                    }
                });
        };

        window.confirmarAñadir = function() {
            if (!productoTemporal) return;

            const tbody = document.querySelector("#tablaProductos tbody");
            const fila = `
            <tr>
                <td>
                    <input type="number" class="form-control form-control-sm" value="1" min="1"
                           oninput="recalcularTotal()" onchange="recalcularTotal()">
                </td>
                <td>${productoTemporal.nombre}</td>
                <td>${productoTemporal.precioUnitario.toFixed(2)}</td>
                <td class="importe-col">${productoTemporal.precioUnitario.toFixed(2)}</td>
                <td>
                    <button type="button" class="btn btn-outline-danger btn-sm"
                            onclick="this.closest('tr').remove(); recalcularTotal();">×</button>
                </td>
            </tr>`;

            tbody.insertAdjacentHTML('beforeend', fila);
            document.getElementById('productoBusqueda').value = "";
            document.getElementById('btnAñadirLista').disabled = true;
            document.getElementById('productoFeedback').textContent = "";
            productoTemporal = null;
            recalcularTotal();
        };

            function recalcularTotal() {
            let totalGeneral = 0;
            document.querySelectorAll("#tablaProductos tbody tr").forEach(fila => {
                const inputCantidad = fila.querySelector('input');
                const cantidad = parseFloat(inputCantidad.value) || 0;
                const precio = parseFloat(fila.cells[2].textContent) || 0;
                const importeFila = cantidad * precio;
                fila.cells[3].textContent = importeFila.toFixed(2);
                totalGeneral += importeFila;
            });
            const etiquetaTotal = document.getElementById("totalVenta");
            if (etiquetaTotal) {
                etiquetaTotal.textContent = totalGeneral.toFixed(2);
            }
        }
    </script>
}
