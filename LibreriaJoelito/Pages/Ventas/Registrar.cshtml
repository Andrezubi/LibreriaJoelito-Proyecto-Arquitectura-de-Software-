@page
@model LibreriaJoelito.Pages.Ventas.RegistrarModel
@{
    ViewData["Title"] = "Registrar Venta";
}

<div class="ventas-page">
    <div class="content-area">
        <div class="ventas-card">
            <h2 class="ventas-titulo">REGISTRO DE VENTA</h2>

            <div class="card p-4 shadow-sm mb-4">
                <form method="post" id="ventaForm">
                    @Html.AntiForgeryToken()

                    <div class="row g-3 align-items-center bg-light p-3 rounded border">

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Fecha:</label>
                            <input type="text" class="form-control" value="@DateTime.Now.ToString("dd/MM/yyyy")" disabled>
                        </div>

                        <div class="col-md-3">
                            <label for="ciCliente" class="form-label fw-bold">
                                CI/NIT Cliente: <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input type="text" id="ciCliente" class="form-control" placeholder="Buscar CI/NIT..." required autocomplete="off">
                                <span class="input-group-text bg-white">🔍</span>
                                <div id="ciDropdown" class="dropdown-ci"></div>
                            </div>
                            <small id="clienteFeedback" class="form-text text-muted"></small>
                        </div>

                        <div class="col-md-6">
                            <label for="nombreCliente" class="form-label fw-bold">Cliente/Razón Social:</label>
                            <div class="input-group">
                                <input type="hidden" id="idCliente" name="IdCliente" required>
                                <input type="text" id="nombreCliente" class="form-control bg-white" readonly placeholder="El nombre aparecerá automáticamente">

                                <button type="button" class="btn btn-crear" id="btnCrearClienteRapido">
                                    +
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="ventas-footer">
                        <button type="submit" class="btn btn-guardar" id="btnGuardarVenta">
                            Guardar Venta
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <!-- ================= MODAL CREAR CLIENTE ================= -->
    <div class="modal fade" id="modalCliente" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <!-- HEADER -->
                <div class="modal-header modal-header-morado">
                    <h5 class="modal-title">Nuevo Cliente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <div class="form-container" style="box-shadow:none; border:none; padding:0;">

                        <form id="formClienteModal">
                            @Html.AntiForgeryToken()

                            <!-- NOMBRE -->
                            <div class="form-group mb-3">
                                <label class="form-label fw-bold">Nombre</label>
                                <input type="text" id="modalNombre" class="form-control" placeholder="Ej: Juan" required>
                            </div>

                            <!-- APELLIDOS -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Apellido Paterno</label>
                                    <input type="text" id="modalApellidoP" class="form-control" placeholder="Ej: Pérez" required>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Apellido Materno (Opcional)</label>
                                    <input type="text" id="modalApellidoM" class="form-control" placeholder="Ej: López">
                                </div>
                            </div>

                            <!-- CI + COMPLEMENTO -->
                            <div class="row">
                                <div class="col-md-8 mb-3">
                                    <label class="form-label fw-bold">Carnet de Identidad</label>
                                    <input type="text" id="modalCi" class="form-control" placeholder="Ej: 1234567" required>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Complemento</label>
                                    <input type="text" id="modalComplemento" class="form-control" placeholder="Ej: 1A">
                                </div>
                            </div>

                            <!-- EMAIL -->
                            <div class="form-group mb-3">
                                <label class="form-label">Correo Electrónico</label>
                                <input type="email" id="modalEmail" class="form-control" placeholder="juan@ejemplo.com">
                            </div>

                            <!-- CHECK -->
                            <div class="form-group mb-3">
                                <div class="form-check">
                                    <input type="checkbox" id="modalFrecuente" class="form-check-input">
                                    <label class="form-check-label">Es Cliente Frecuente</label>
                                </div>
                            </div>

                            <small id="modalFeedback" class="text-danger"></small>

                        </form>
                    </div>
                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-cancelar" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-sistema" id="btnGuardarClienteModal">
                        Registrar Cliente
                    </button>
                </div>

            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {


            const ciInput = document.getElementById('ciCliente');
            const nombreInput = document.getElementById('nombreCliente');
            const idClienteInput = document.getElementById('idCliente');
            const feedback = document.getElementById('clienteFeedback');
            const btnGuardarVenta = document.getElementById('btnGuardarVenta');
            const modalComplemento = document.getElementById('modalComplemento');
            const modalFrecuente = document.getElementById('modalFrecuente');
            let timeoutId;
            const dropdown = document.getElementById('ciDropdown');
                    ciInput.addEventListener('input', function () {
            const value = this.value.trim();

            if (value.length < 2) {
                dropdown.style.display = 'none';
                return;
            }

            fetch(`?handler=BuscarClientesParcial&ci=${value}`)
                .then(res => res.json())
                .then(data => {

                    dropdown.innerHTML = '';

                    if (!data.success || data.clientes.length === 0) {
                        dropdown.style.display = 'none';
                        return;
                    }

                    data.clientes.forEach(c => {
                        const item = document.createElement('div');
                        item.classList.add('dropdown-item-ci');

                        const apellidoM = c.apellidoMaterno ? ' ' + c.apellidoMaterno : '';

                        item.innerHTML = `
                            <strong>${c.ci}</strong>
                            <span>${c.nombre} ${c.apellidoPaterno}${apellidoM}</span>
                        `;

                        item.addEventListener('click', () => {
                            ciInput.value = c.ci;
                            nombreInput.value = `${c.nombre} ${c.apellidoPaterno}${apellidoM}`;
                            idClienteInput.value = c.id;

                            dropdown.style.display = 'none';

                            ciInput.classList.remove('is-invalid');
                            ciInput.classList.add('is-valid');

                            feedback.textContent = "Cliente seleccionado.";
                            feedback.className = "form-text text-success";
                        });

                        dropdown.appendChild(item);
                    });

                    dropdown.style.display = 'block';
                })
                .catch(err => {
                    console.error(err);
                    dropdown.style.display = 'none';
                });
        });

        /* cerrar dropdown si hace click afuera */
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.input-group')) {
                dropdown.style.display = 'none';
            }
        });

            const form = document.getElementById('ventaForm');
            form.addEventListener('submit', function(e) {
                if (!idClienteInput.value) {
                    e.preventDefault();
                    feedback.textContent = "Debe buscar y seleccionar un cliente válido para continuar.";
                    feedback.className = "form-text text-danger fw-bold";
                    ciInput.classList.add('is-invalid');
                }
            });

            ciInput.addEventListener('input', function () {
                const ciValue = this.value.trim();

                nombreInput.value = '';
                idClienteInput.value = '';
                feedback.textContent = '';
                ciInput.classList.remove('is-invalid', 'is-valid');

                if (ciValue.length >= 4) {
                    clearTimeout(timeoutId);

                    timeoutId = setTimeout(() => {
                        feedback.textContent = "Buscando...";
                        feedback.className = "form-text text-info";

                        fetch(`?handler=BuscarCliente&ci=${encodeURIComponent(ciValue)}`)
                            .then(response => {
                                if (!response.ok) throw new Error("Error en la conexión");
                                return response.json();
                            })
                            .then(data => {
                                if (data.success) {
                                    const c = data.cliente;
                                    const apellidoM = c.apellidoMaterno ? ' ' + c.apellidoMaterno : '';
                                    nombreInput.value = `${c.nombre} ${c.apellidoPaterno}${apellidoM}`;
                                    idClienteInput.value = c.id;

                                    feedback.textContent = "Cliente encontrado.";
                                    feedback.className = "form-text text-success";
                                    ciInput.classList.add('is-valid');
                                } else {
                                    feedback.textContent = "Cliente no encontrado. Use el botón '+' para agregarlo.";
                                    feedback.className = "form-text text-danger";
                                    ciInput.classList.add('is-invalid');
                                }
                            })
                            .catch(error => {
                                console.error('Error fetching client:', error);
                                feedback.textContent = "Error al buscar cliente.";
                                feedback.className = "form-text text-danger";
                            });
                    }, 400);
                }
            });

            const modal = new bootstrap.Modal(document.getElementById('modalCliente'));
            const btnCrearCliente = document.getElementById('btnCrearClienteRapido');

            const modalCi = document.getElementById('modalCi');
            const modalNombre = document.getElementById('modalNombre');
            const modalApellidoP = document.getElementById('modalApellidoP');
            const modalApellidoM = document.getElementById('modalApellidoM');
            const modalEmail = document.getElementById('modalEmail');
            const modalFeedback = document.getElementById('modalFeedback');

            const btnGuardarClienteModal = document.getElementById('btnGuardarClienteModal');

            btnCrearCliente.addEventListener('click', () => {
                modalCi.value = ciInput.value;
                modal.show();
            });

            btnGuardarClienteModal.addEventListener('click', () => {

                       const data = {
            Ci: modalCi.value,
            Nombre: modalNombre.value,
            ApellidoPaterno: modalApellidoP.value,
            ApellidoMaterno: modalApellidoM.value,
            Complemento: modalComplemento.value,
            Email: modalEmail.value,
            ClienteFrecuente: modalFrecuente.checked
        };
                fetch('?handler=CrearCliente', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken':
                            document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify(data)
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const c = data.cliente;
                        const apellidoM = c.apellidoMaterno ? ' ' + c.apellidoMaterno : '';

                        nombreInput.value = `${c.nombre} ${c.apellidoPaterno}${apellidoM}`;
                        idClienteInput.value = c.id;
                        ciInput.value = c.ci;

                        feedback.textContent = "Cliente creado y seleccionado.";
                        feedback.className = "form-text text-success";

                        ciInput.classList.remove('is-invalid');
                        ciInput.classList.add('is-valid');

                        modal.hide();
                    } else {
                        modalFeedback.textContent = data.message;
                    }
                })
                .catch(err => {
                    console.error(err);
                    modalFeedback.textContent = "Error al guardar cliente";
                });
            });

        });
    </script>
}


