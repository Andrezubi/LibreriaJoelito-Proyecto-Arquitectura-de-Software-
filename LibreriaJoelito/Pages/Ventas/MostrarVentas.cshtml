@page
@model LibreriaJoelito.Pages.Ventas.MostrarVentasModel
@{
    ViewData["Title"] = "Ventas";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-center">
        <div class="tabla-wrapper">

            <div class="card shadow-sm tabla-card">

                <!-- HEADER -->
                <div class="card-header d-flex justify-content-between align-items-center tabla-header-custom">

                    <h5 class="mb-0">Lista de Ventas</h5>

                   
                    <a asp-page="Registrar" class="btn btn-sistema btn-sm">
                        + Registrar Venta
                    </a>

                </div>

                @if (!string.IsNullOrEmpty(Model.MensajeExito))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @Model.MensajeExito
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="card-body p-0">
                    <div class="table-responsive">

                        <table class="table table-hover align-middle mb-0">

                            <thead class="tabla-head-custom">
                                <tr>
                                    <th>CI Cliente</th>
                                    <th>Fecha</th>
                                    <th>Total</th>
                                    <th>Empleado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (System.Data.DataRow row in Model.VentasDataTable.Rows)
                                {
                                    <tr>
                                        <td>@row["CiCliente"]</td>
                                        <td>@Convert.ToDateTime(row["Fecha"]).ToString("dd/MM/yyyy")</td>
                                        <td>@row["Total"] Bs</td>
                                        <td>@row["NombreEmpleado"]</td>

                                        <td>

                                           
                                            <a class="btn btn-sistema btn-sm"
                                               asp-page="DetalleVenta"
                                               asp-route-id="@row["Id"]">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                    
                                            <a class="btn btn-danger btn-sm"
                                               asp-page-handler="ExportarPdf"
                                               asp-route-id="@row["Id"]">
                                                <i class="bi bi-file-earmark-pdf"></i>
                                            </a>

                                            <a data-bs-toggle="modal"
                                               data-bs-target="#modalAnular-@row["Id"]"
                                               class="btn btn-warning btn-sm">
                                                <i class="bi bi-x-circle"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>