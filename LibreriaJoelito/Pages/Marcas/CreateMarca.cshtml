@page
@model LibreriaJoelito.Pages.Marcas.CreateMarcaModel
@{
    ViewData["Title"] = "Nueva Marca";
}

<div class="form-container">
    <div class="form-header">
        Nueva Marca
    </div>

    <form method="post">
        <div class="form-group mb-3">
            <label asp-for="Marca.Nombre" class="form-label font-weight-bold">Nombre de la Marca <span class="text-danger">*</span></label>
            <input asp-for="Marca.Nombre" class="form-control" placeholder="Ej: Faber-Castell" required />
            <span asp-validation-for="Marca.Nombre" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 form-group mb-3">
                <label asp-for="Marca.Industria" class="form-label">Industria</label>
                <input asp-for="Marca.Industria" class="form-control" placeholder="Ej: Papelería o Tecnología" />
                <span asp-validation-for="Marca.Industria" class="text-danger"></span>
            </div>

            <div class="col-md-6 form-group mb-3">
                <label asp-for="Marca.PaginaWeb" class="form-label">Página Web</label>
                <input asp-for="Marca.PaginaWeb" class="form-control" placeholder="Ej: www.faber-castell.com" />
                <span asp-validation-for="Marca.PaginaWeb" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Marca.Descripcion" class="form-label">Descripción</label>
            <textarea asp-for="Marca.Descripcion" class="form-control" rows="3" placeholder="Breve descripción de la marca o proveedor..."></textarea>
            <span asp-validation-for="Marca.Descripcion" class="text-danger"></span>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-sistema">Registrar Marca</button>
            <a asp-page="VerMarcas" class="btn btn-cancelar ms-2">Cancelar y Volver</a>
        </div>
    </form>
</div>