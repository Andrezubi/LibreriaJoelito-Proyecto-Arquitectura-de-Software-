@page
@model LibreriaJoelito.Pages.LogIn.InicioSesionModel
@{
    ViewData["OcultarSidebar"] = true;
}

<div class="login-container">
    <div class="login-card">

        <div class="login-header">
            <h3>Iniciar Sesión</h3>
        </div>

        <div class="login-body">

            <form method="post">

                <div class="input-group-custom">
                    <span>👤</span>
                    <input asp-for="Username" type="text" placeholder="Usuario" />
                </div>

                <div class="input-group-custom">
                    <span>🔒</span>
                    <input asp-for="Password" type="password" placeholder="Contraseña" />
                </div>

                <div class="login-btn-container">
                    <button type="submit" class="btn btn-sistema-danger">Ingresar</button>
                </div>

                <p style="color:red">@Model.ErrorMessage</p>

                <div class="login-extra">
                    <label><input type="checkbox"> Recordarme</label>
                    <a href="#">¿Olvidaste contraseña?</a>
                </div>

                <div class="login-buttons">
                    <a href="/Registro" class="btn btn-sistema">Crear Cuenta</a>
                    <a href="/Index" class="btn btn-cancelar">Volver al inicio</a>
                </div>

            </form>

        </div>
    </div>
</div>