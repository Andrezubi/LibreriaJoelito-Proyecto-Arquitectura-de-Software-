@page
@model LibreriaJoelito.Pages.LogIn.InicioSesionModel
@{
    ViewData["OcultarSidebar"] = true;
}

<!-- LOGIN -->
<div class="login-container">

    <div class="login-card">

        <div class="login-header">
            <h3>Iniciar Sesión</h3>
        </div>

        <div class="login-body">

            <div class="input-group-custom">
                <span>👤</span>
                <input type="text" placeholder="Usuario">
            </div>

            <div class="input-group-custom">
                <span>🔒</span>
                <input type="password" placeholder="Contraseña">
            </div>

                <div class="login-btn-container">
                    <button class="btn btn-sistema-danger">Ingresar</button>
                </div>

            <div class="login-extra">
                <label><input type="checkbox"> Recordarme</label>
                <a href="#">¿Olvidaste contraseña?</a>
            </div>

            <div class="login-buttons">
                    <button type="submit" class="btn btn-sistema">Crear Cuenta</button>
                    <a href="/Index" class="btn btn-cancelar">Volver al inicio</a>
            </div>
        </div>

    </div>

</div>
